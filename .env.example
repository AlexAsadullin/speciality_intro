# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production

# App database URL (used by app container; matches postgres service above)
DATABASE_URL=postgresql+asyncpg://trading_user:change_me_in_production@postgres:5432/trading_data

# JWT — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change_me_in_production

# MinIO
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret
MINIO_ENDPOINT=localhost:9000
MINIO_BUCKET=trading-data

# MOEX AlgoPack (optional; obstats/tradestats/orderstats require a paid subscription)
# https://data.moex.com
MOEX_ALGOPACK_TOKEN=

# Loader scratch dir (overridden to /tmp/data in Docker)
DATA_ROOT=/tmp/data
